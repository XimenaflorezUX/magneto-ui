# --- DEPENDENCIAS ---
# No subimos las librerías porque pesan mucho y se instalan con 'yarn install'
node_modules/
jspm_packages/

# --- COMPILACIÓN Y CACHÉ ---
# Archivos temporales que genera Storybook y Webpack
.cache/
dist/
build/
.eslintcache
*.tsbuildinfo

# --- STORYBOOK ---
# La versión estática que se genera para publicar
storybook-static/

# --- TOKENS (GENERADOS AUTOMÁTICAMENTE) ---
# Si estos archivos los crea el script 'generateTokens.js', no deben subirse
# porque se regeneran en cada PC.
src/@types/tokens.d.ts
src/shared/stylesheets/tokens/
src/shared/tokens/index.ts

# --- SCRIPTS DE SISTEMA Y LOGS ---
# Basura que genera Windows o errores de procesos
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# --- CONFIGURACIÓN DE IDE (Cursor/VS Code) ---
.idea/
.vscode/
.zed/